<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="悬浮窗计算器 · 3秒看清这单值不值得接"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:padding="14dp"
            android:background="@drawable/chip_background"
            android:textSize="16sp"
            android:text="@string/status_stopped" />

        <Button
            android:id="@+id/startBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/btn_start" />

        <Button
            android:id="@+id/stopBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_stop"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/settingsBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_settings"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/historyBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_history"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/resetTimerBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_reset_timer"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/accessibilityBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_accessibility"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/ocrBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_ocr"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/ocrTestBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_ocr_test"
            style="?attr/materialButtonOutlinedStyle" />

        <TextView
            android:id="@+id/idleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@drawable/chip_background"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:textColor="@color/text_primary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="@color/divider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="使用流程"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="1. 点&#8220;启动悬浮窗&#8221;，允许&#8220;在其他应用上层显示&#8221;权限\n2. 悬浮球会一直漂在屏幕上（可拖动）\n3. Uber 派单来了，看一眼订单金额 / 公里 / 分钟\n4. 点悬浮球 → 输入 3 个数 → 立刻看到 Go/No-Go\n5. 不想用时点&#8220;关闭悬浮窗&#8221;或状态栏通知关闭"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="当前阈值（可在设置中修改）"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/thresholdPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textColor="@color/text_primary" />

    </LinearLayout>

</ScrollView>
